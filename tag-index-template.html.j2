<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tags - Covenantal Biblicist</title>
  <link rel="stylesheet" href="../css/style.css">
  <script data-goatcounter="https://covenantbiblicist.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</head>
<body>
  <div id="header">
    <h1><a href="../index.html">Covenantal Biblicist</a></h1>
  </div>
  <div id="content">
    <h2>Tags</h2>
    <ul class="tag-list">
      {% for tag in tags %}
      <li>
        <a href="{{ tag.name | replace(' ', '-') | lower }}/">
          {{ tag.name }} <span class="tag-count">({{ tag.count }})</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>
  <div class="build-id" data-build-id="{{ build_id }}" data-build-iso="{{ build_iso }}" data-gc-path="/tags/"><span class="build-id-text">Build ID: {{ build_id }}</span> &middot; <span class="views">Views: --</span></div>
  <script src="../js/visitor-count.js"></script>
</body>
</html>

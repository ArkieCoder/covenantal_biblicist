<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tags - Covenantal Biblicist</title>
  <link rel="stylesheet" href="../css/style.css">
  <script data-goatcounter="https://covenantbiblicist.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</head>
<body>
  <div id="header">
    <h1><a href="../index.html">Covenantal Biblicist</a></h1>
  </div>
  <div id="content">
    <h2>Tags</h2>
    <ul class="tag-list">
      {% for tag in tags %}
      <li>
        <a href="{{ tag.name | replace(' ', '-') | lower }}/">
          {{ tag.name }} <span class="tag-count">({{ tag.count }})</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>
  <div class="build-id" data-build-id="{{ build_id }}" data-build-iso="{{ build_iso }}">Build ID: {{ build_id }}</div>
  <script>
    document.querySelectorAll('.build-id[data-build-id]').forEach(function(el) {
      var ts = parseInt(el.getAttribute('data-build-id'), 10) * 1000;
      var d = new Date(ts);
      var pad = function(n) { return n < 10 ? '0' + n : n; };
      var offset = -d.getTimezoneOffset();
      var sign = offset >= 0 ? '+' : '-';
      var oh = pad(Math.floor(Math.abs(offset) / 60));
      var om = pad(Math.abs(offset) % 60);
      el.title = d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()) +
        'T' + pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds()) +
        sign + oh + ':' + om;
    });
  </script>
</body>
</html>

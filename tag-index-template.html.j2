<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tags - Covenantal Biblicist</title>
  <link rel="stylesheet" href="../css/style.css">
</head>
<body>
  <div id="header">
    <h1><a href="../index.html">Covenantal Biblicist</a></h1>
  </div>
  <div id="content">
    <h2>Tags</h2>
    <ul class="tag-list">
      {% for tag in tags %}
      <li>
        <a href="{{ tag.name | replace(' ', '-') | lower }}/">
          {{ tag.name }} <span class="tag-count">({{ tag.count }})</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>
</body>
</html>

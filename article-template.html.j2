<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Covenantal Biblicist</title>
  <link rel="stylesheet" href="../css/style.css">
</head>
<body>
  <div id="header">
    <h1><a href="../index.html">Covenantal Biblicist</a></h1>
    <nav>
      <a href="../tags/">Tags</a>
    </nav>
  </div>
  <div id="adobe-dc-view"></div>
  <a id="download-btn" href="{{ article_name }}.pdf" onclick="window.open(this.href); return false;">Download PDF</a>
  <div id="footer-title">Covenantal Biblicist</div>
  <div id="page-cover"></div>

  <script src="https://acrobatservices.adobe.com/view-sdk/viewer.js"></script>
  <script type="text/javascript">
    document.addEventListener("adobe_dc_view_sdk.ready", function () {
      function getPdfVariant() {
        if (window.matchMedia("(max-width: 599px)").matches) return "mobile";
        if (window.matchMedia("(max-width: 1023px)").matches) return "tablet";
        return "embed";
      }

      var variant = getPdfVariant();
      var pdfUrl = "{{ article_name }}-" + variant + ".pdf";

      var adobeDCView = new AdobeDC.View({
        clientId: "bd4cb7ccbcdc4940adb98b75683d410a",
        divId: "adobe-dc-view"
      });
      adobeDCView.previewFile(
        {
          content: { location: { url: pdfUrl } },
          metaData: { fileName: "{{ article_name }}.pdf" }
        },
        { embedMode: "IN_LINE" }
      );
    });
    var footerTitle = document.getElementById("footer-title");
    var header = document.getElementById("header");
    window.addEventListener("scroll", function () {
      var headerBottom = header.getBoundingClientRect().bottom;
      if (headerBottom < 0) {
        footerTitle.classList.add("visible");
      } else {
        footerTitle.classList.remove("visible");
      }
    });
  </script>
</body>
</html>

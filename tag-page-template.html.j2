<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ tag }} - Covenantal Biblicist</title>
  <link rel="stylesheet" href="../../css/style.css">
</head>
<body>
  <div id="header">
    <h1><a href="../../index.html">Covenantal Biblicist</a></h1>
  </div>
  <div id="content">
    <a class="back-link" href="../index.html">&larr; All tags</a>
    <h2>{{ tag }}</h2>
    {% for article in articles %}
    <div class="article-card">
      <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
      <div class="meta">{{ article.author }} &middot; {{ article.date }}</div>
      <p class="description">{{ article.description }}</p>
    </div>
    {% endfor %}
  </div>
  <div class="build-id" data-build-id="{{ build_id }}" data-build-iso="{{ build_iso }}">Build ID: {{ build_id }}</div>
  <script>
    document.querySelectorAll('.build-id[data-build-id]').forEach(function(el) {
      var ts = parseInt(el.getAttribute('data-build-id'), 10) * 1000;
      var d = new Date(ts);
      var pad = function(n) { return n < 10 ? '0' + n : n; };
      var offset = -d.getTimezoneOffset();
      var sign = offset >= 0 ? '+' : '-';
      var oh = pad(Math.floor(Math.abs(offset) / 60));
      var om = pad(Math.abs(offset) % 60);
      el.title = d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()) +
        'T' + pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds()) +
        sign + oh + ':' + om;
    });
  </script>
</body>
</html>

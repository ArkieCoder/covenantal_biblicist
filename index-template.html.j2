<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Covenantal Biblicist</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <div id="header">
    <h1><a href="index.html">Covenantal Biblicist</a></h1>
  </div>
  <div id="content">
    <div id="controls">
      <input type="text" id="search" placeholder="Search articles...">
      <select id="sort">
        <option value="date-desc">Newest first</option>
        <option value="date-asc">Oldest first</option>
        <option value="title-asc">Title A-Z</option>
        <option value="title-desc">Title Z-A</option>
        <option value="author">By author</option>
      </select>
    </div>
    <div id="articles"></div>
    <div id="no-results">No articles found.</div>
  </div>

  <script>
    var articles = {{ articles }};

    function formatDate(dateStr) {
      var months = ['January','February','March','April','May','June',
                    'July','August','September','October','November','December'];
      var parts = dateStr.split('-');
      return months[parseInt(parts[1],10)-1] + ' ' + parseInt(parts[2],10) + ', ' + parts[0];
    }

    function sortArticles(arts, criteria) {
      var sorted = arts.slice();
      switch(criteria) {
        case 'date-desc':
          sorted.sort(function(a,b) { return new Date(b.date) - new Date(a.date); });
          break;
        case 'date-asc':
          sorted.sort(function(a,b) { return new Date(a.date) - new Date(b.date); });
          break;
        case 'title-asc':
          sorted.sort(function(a,b) { return a.title.localeCompare(b.title); });
          break;
        case 'title-desc':
          sorted.sort(function(a,b) { return b.title.localeCompare(a.title); });
          break;
        case 'author':
          sorted.sort(function(a,b) { return a.author.localeCompare(b.author); });
          break;
      }
      return sorted;
    }

    function renderArticles(arts) {
      var container = document.getElementById('articles');
      var noResults = document.getElementById('no-results');
      container.innerHTML = '';

      if (arts.length === 0) {
        noResults.style.display = 'block';
        return;
      }
      noResults.style.display = 'none';

      arts.forEach(function(article) {
        var card = document.createElement('div');
        card.className = 'article-card';

        var h2 = document.createElement('h2');
        var link = document.createElement('a');
        link.href = article.url;
        link.textContent = article.title;
        h2.appendChild(link);

        var caret = document.createElement('span');
        caret.className = 'caret';
        caret.textContent = '\u25BE';
        caret.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var abstract = card.querySelector('.abstract');
          var isExpanded = abstract.style.display === 'block';
          abstract.style.display = isExpanded ? 'none' : 'block';
          this.classList.toggle('expanded');
        });
        h2.appendChild(caret);

        var meta = document.createElement('div');
        meta.className = 'meta';
        meta.textContent = article.author + ' \u00B7 ' + formatDate(article.date);

        var abs = document.createElement('div');
        abs.className = 'abstract';

        // Parse abstract paragraphs
        var tempDiv = document.createElement('div');
        tempDiv.innerHTML = article.abstract;
        var paragraphs = tempDiv.querySelectorAll('p');

        // Add all paragraphs except the last
        for (var i = 0; i < paragraphs.length - 1; i++) {
          abs.appendChild(paragraphs[i]);
        }

        // Create footer with last paragraph and read-more on same line
        if (paragraphs.length > 0) {
          var footer = document.createElement('div');
          footer.className = 'abstract-footer';
          footer.appendChild(paragraphs[paragraphs.length - 1]);

          var readMore = document.createElement('a');
          readMore.className = 'read-more';
          readMore.href = article.url;
          readMore.innerHTML = 'Read <span class="finger">\u261E</span>';
          footer.appendChild(readMore);

          abs.appendChild(footer);
        }

        card.appendChild(h2);
        card.appendChild(meta);
        card.appendChild(abs);
        container.appendChild(card);
      });
    }

    var currentSort = 'date-desc';

    document.getElementById('sort').addEventListener('change', function() {
      currentSort = this.value;
      renderArticles(sortArticles(articles, currentSort));
    });

    document.getElementById('search').addEventListener('input', function() {
      var query = this.value.toLowerCase();
      if (query.length < 2) {
        renderArticles(sortArticles(articles, currentSort));
        return;
      }
      var filtered = articles.filter(function(a) {
        return a.title.toLowerCase().indexOf(query) !== -1 ||
               a.description.toLowerCase().indexOf(query) !== -1 ||
               a.author.toLowerCase().indexOf(query) !== -1 ||
               (a.abstract && a.abstract.toLowerCase().indexOf(query) !== -1) ||
               (a.tags && a.tags.some(function(t) { return t.toLowerCase().indexOf(query) !== -1; }));
      });
      renderArticles(filtered);
    });

    renderArticles(sortArticles(articles, currentSort));
  </script>
</body>
</html>
